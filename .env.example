# -----------------------------------------------------------------------
# keenchic-API-Gateway — environment variable template
# Copy to .env and fill in values. Never commit .env to version control.
# -----------------------------------------------------------------------

# Required: static API key checked on every protected endpoint (X-API-KEY header)
KEENCHIC_API_KEY=

# Backend selection for inference engine
# Options: GPU (TensorRT, auto-fallback to OpenVINO if unsupported), CPU (OpenVINO only), AUTO
KEENCHIC_BACKEND=GPU

# Optional: absolute path to a directory for saving raw uploaded images
# Leave empty to disable
KEENCHIC_UPLOAD_DIR=
